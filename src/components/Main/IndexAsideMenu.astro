---
import { IconHome } from '@/components/Icons.jsx'

interface Props {
  path: string
}

const { path } = Astro.props
---

<aside id='indexAsideMenu' class='
  fixed top-14 left-[var(--left)] [--left:-240px] [transition:left_.3s_ease] w-60 h-[calc(100dvh-56px)] z-[2] bg-primary flex flex-col items-center [scrollbar-gutter:stable] px-3 py-3 gap-2
  [&>section]:w-full [&>section]:h-fit [&>section]:flex [&>section]:flex-col [&>section]:border-b-[1px] [&>section]:border-[#3F3F3F]
  [&>section>a]:max-w-[204px] [&>section>a]:h-10 [&>section>a]:min-h-10 [&>section>a]:flex [&>section>a]:items-center [&>section>a]:gap-6 [&>section>a]:px-3 [&>section>a]:rounded-lg  [&>section>a]:cursor-pointer [&>section>a.actualPath]:bg-neutral-800
  [&>section>a:hover]:bg-neutral-800 [&>section>a.actualPath:hover]:bg-neutral-700
   [&>section>a:active]:bg-neutral-600
  [&>section>a>p]:text-sm [&>section>a>p]:text-nowrap [&>section>a>p]:overflow-ellipsis [&>section>a>p]:overflow-hidden
  [&_div]:h-6 [&_div]:aspect-square
'>
  <section>
    <a class={path === '/' ? 'actualPath' : ''}>
      <div>
        <IconHome active={path === '/'} />
      </div>
      <p>Principal</p>
    </a>
    <a class={path === '#' ? 'actualPath' : ''}>
      <div></div>
      <p>Shorts</p>
    </a>
    <a class={path === '#' ? 'actualPath' : ''}>
      <div></div>
      <p>Suscripciones</p>
    </a>
  </section>
  <div class='separador'></div>
  <section>

  </section>
  <div class='separador'></div>
  <section>

  </section>
  <div class='separador'></div>
  <section>

  </section>
  <div class='separador'></div>
  <section>

  </section>
  <div class='separador'></div>
  <section>

  </section>
  <div class='separador'></div>
  <section>
    <a class={path === '#' ? 'bg-neutral-800' : ''}>Acerca de este proyecto</a>
  </section>
</aside>